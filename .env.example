# ─────────────────────────────────────────────────────────────
#  Alek — Variables de entorno (PLANTILLA)
#  Copia este fichero como ".env" y rellena tus claves reales.
#  El fichero ".env" NUNCA debe subirse a un repositorio
#  ni compartirse fuera de tu entorno local (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# ── APIs externas ───────────────────────────────────────────
ANTHROPIC_API_KEY=
NETLAS_API_KEY=
HIBP_API_KEY=
OTX_API_KEY=

# ── Email (alertas y resúmenes automáticos) ─────────────────
ALERT_EMAIL_ORIGEN=
ALERT_EMAIL_PASSWORD=

# ── Acceso al dashboard ──────────────────────────────────────
# Credenciales de acceso al panel Alek. Cámbialas antes de
# cualquier demo o entrega a cliente.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=cambia-esta-contrasena
